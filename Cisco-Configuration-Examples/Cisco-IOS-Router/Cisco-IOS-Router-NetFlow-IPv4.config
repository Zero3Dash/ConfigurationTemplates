!--------------------------------------------------------------------------
! For Cisco IOS-XE Routers
!--------------------------------------------------------------------------
! Implement NeFlow Configuration for LogicMonitor
!--------------------------------------------------------------------------
!
!--save current configuration
write memory
!
!--configure mode
configure terminal
!
!--create NetFlow record for inbound packets
flow record nf.record.input.v4
 description input-v4-for-{{layer3_interface}}
 match flow direction
 match ipv4 protocol
 match ipv4 source address
 match ipv4 destination address
 match transport source-port
 match transport destination-port
 match application name
 match interface input
 match ipv4 tos
 match policy qos classification hierarchy
 collect ipv4 source mask
 collect ipv4 destination prefix
 collect ipv4 destination mask
 collect counter bytes long
 collect counter packets long
 collect timestamp sys-uptime first
 collect timestamp sys-uptime last
 collect policy qos queue index
 collect routing source as
 collect routing destination as
 collect routing next-hop address ipv4
exit
!
!--create NetFlow record for outbound packets
flow record nf.record.output.v4
 description output-v4-for-{{layer3_interface}}
 match flow direction
 match ipv4 protocol
 match ipv4 source address
 match ipv4 destination address
 match transport source-port
 match transport destination-port
 match application name
 match interface output
 match ipv4 tos
 match policy qos classification hierarchy
 collect ipv4 source mask
 collect ipv4 destination prefix
 collect ipv4 destination mask
 collect counter bytes long
 collect counter packets long
 collect timestamp sys-uptime first
 collect timestamp sys-uptime last
 collect policy qos queue index
 collect routing source as
 collect routing destination as
 collect routing next-hop address ipv4
exit
!
!--create an export NetFlow collector destination
flow exporter nf.exporter
 destination {{netflow_collector_ip}}
 source {{netflow_source_ip}}
 transport udp 2055
 template data timeout 60
 option interface-table timeout 60
 option application-table timeout 60
exit
!
!--create a NetFlow interface monitor for inbound packets
flow monitor nf.monitor.input.v4
 exporter nf.exporter
 cache timeout active 60
 cache timeout inactive 120
 record nf.record.input.v4
exit
!
!--create a NetFlow interface monitor for outbound packets
flow monitor nf.monitor.output.v4
 exporter nf.exporter
 cache timeout active 60
 cache timeout inactive 120
 record nf.record.output.v4
exit
!
!--assign the NetFlow monitors to an interface
interface {{layer3_interface}}
 ip nbar protocol-discovery
 ip flow monitor nf.monitor.input.v4 input
 ip flow monitor nf.monitor.output.v4 output
end
!
!--save modified configuration
write memory
!
!--------------------------------------------------------------------------
! Remove NeFlow Configuration for LogicMonitor
!--------------------------------------------------------------------------
!
!--save current configuration
write memory
!
!--configure mode
configure terminal
!
!--remove the NetFlow monitors to an interface
interace {{layer3_interface}}
 no ip flow monitor nf.monitor.input.v4 input
 no ip flow monitor nf.monitor.output.v4 output
exit
!--remove a NetFlow interface monitor for inbound packets
no flow monitor nf.monitor.input.v4
!
!--remove a NetFlow interface monitor for outbound packets
no flow monitor nf.monitor.output.v4
!
!--remove an export NetFlow collector destination
no flow exporter nf.exporter
!
!--remove NetFlow record for inbound packets
no flow record nf.record.input.v4
!
!--remove NetFlow record for outbound packets
no flow record nf.record.output.v4
!
!--exit configure mode
end
!
!--save modified configuration
write memory
!
!--------------------------------------------------------------------------
! Validate NeFlow Configuration for LogicMonitor
!--------------------------------------------------------------------------
!
show flow record nf.record.input.v4
show flow record nf.record.output.v4
show flow monitor
show flow monitor nf.monitor.input.v4 statistics
show flow monitor nf.monitor.output.v4 statistics
show flow monitor nf.monitor.input.v4 cache
show flow monitor nf.monitor.output.v4 cache
show flow exporter nf.exporter
show flow exporter statistics
!